import "next-auth"
import "next-auth/jwt"

type CommandCenterClaims = {
  roles?: string[]
  [key: string]: unknown
}

declare module "next-auth" {
  interface Session {
    user: {
      id?: string
      name?: string | null
      email?: string | null
      image?: string | null
      isActive?: boolean
      provider?: string | null
      commandCenterClaims?: CommandCenterClaims
    }
  }
}

declare module "next-auth/jwt" {
  interface JWT {
    userId?: string
    isActive?: boolean
    provider?: string | null
    email?: string | null
    name?: string | null
    commandCenterClaims?: CommandCenterClaims
  }
}
