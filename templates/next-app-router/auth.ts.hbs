import NextAuth from "next-auth"
import Okta from "next-auth/providers/okta"
import Auth0 from "next-auth/providers/auth0"

type UserProfile = {
  id?: string
  email: string
  name?: string | null
  isActive?: boolean
  roles?: string[]
}

async function onUserSignIn(input: {
  email: string
  name: string | null
  provider: string
  providerSubject: string | null
}): Promise<UserProfile | null> {
  // Wire this to your command-center user table.
  // Return null/falsey to deny access.
  return {
    email: input.email,
    name: input.name,
    isActive: true,
    roles: [],
  }
}

async function loadUserProfile(email: string): Promise<UserProfile | null> {
  // Wire this to your command-center user table or profile API.
  return {
    email,
    isActive: true,
    roles: [],
  }
}

function buildSessionClaims(profile: UserProfile | null) {
  return {
    roles: profile?.roles ?? [],
  }
}

const providers: any[] = []

if (process.env.OKTA_ENABLED === "true") {
  providers.push(
    Okta({
      clientId: process.env.OKTA_CLIENT_ID!,
      clientSecret: process.env.OKTA_CLIENT_SECRET!,
      issuer: process.env.OKTA_ISSUER!,
    })
  )
}

if (process.env.AUTH0_ENABLED === "true") {
  providers.push(
    Auth0({
      clientId: process.env.AUTH0_CLIENT_ID!,
      clientSecret: process.env.AUTH0_CLIENT_SECRET!,
      issuer: process.env.AUTH0_ISSUER!,
    })
  )
}

export const { handlers, auth, signIn, signOut } = NextAuth({
  trustHost: true,
  providers,
  session: {
    strategy: "jwt",
    maxAge: 8 * 60 * 60,
  },
  pages: {
    signIn: "/login",
    error: "/login",
  },
  callbacks: {
    async signIn({ user, account }) {
      if (!user.email) return false
      const profile = await onUserSignIn({
        email: user.email,
        name: user.name ?? null,
        provider: account?.provider ?? "unknown",
        providerSubject: account?.providerAccountId ?? null,
      })
      return profile?.isActive !== false
    },

    async jwt({ token, user, account }) {
      const email = user?.email ?? token.email
      if (!email) return token

      const profile = await loadUserProfile(String(email))
      if (profile?.isActive === false) {
        token.isActive = false
        return token
      }

      token.email = String(email)
      token.name = profile?.name ?? user?.name ?? token.name ?? ""
      token.userId = profile?.id
      token.provider = account?.provider ?? token.provider ?? null
      token.isActive = true
      token.commandCenterClaims = buildSessionClaims(profile)
      return token
    },

    async session({ session, token }) {
      if (token.isActive === false) {
        return { ...session, user: undefined as unknown as typeof session.user, expires: new Date(0).toISOString() }
      }

      session.user.id = token.userId as string | undefined
      session.user.email = token.email as string
      session.user.name = token.name as string
      session.user.provider = token.provider as string | null
      session.user.commandCenterClaims = token.commandCenterClaims
      return session
    },
  },
})
